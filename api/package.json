{
  "name": "hyperliquid-api",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "clean": "rimraf dist",
    "build": "NODE_OPTIONS=--openssl-legacy-provider nx build hyperliquid-api --prod",
    "start": "node ./dist/apps/hyperliquid-api/main.js",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider nx serve hyperliquid-api",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"libs/**/*.ts\" \"apps/**/*.ts\"",
    "lint:fix": "eslint \"libs/**/*.ts\" \"apps/**/*.ts\" --fix"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.632.0",
    "@aws-sdk/client-ses": "3.662.0",
    "@aws-sdk/credential-provider-ini": "3.632.0",
    "@logtail/node": "^0.5.6",
    "@nestjs/common": "^7.6.5",
    "@nestjs/config": "^0.6.1",
    "@nestjs/core": "^7.6.5",
    "@nestjs/jwt": "^7.2.0",
    "@nestjs/mongoose": "^7.2.1",
    "@nestjs/passport": "^7.1.5",
    "@nestjs/platform-express": "^7.6.5",
    "@nestjs/platform-ws": "^7.6.5",
    "@nestjs/swagger": "^4.6.1",
    "@nestjs/websockets": "^7.6.5",
    "@nktkas/hyperliquid": "^0.25.5",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.3.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.0.0",
    "express": "^4.19.2",
    "ioredis": "^5.8.2",
    "mongoose": "^5.10.9",
    "passport": "^0.4.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^6.5.5",
    "swagger-ui-express": "^4.1.4",
    "syslog-client": "^1.1.1",
    "uuid": "^8.3.1",
    "ws": "^8.14.0"
