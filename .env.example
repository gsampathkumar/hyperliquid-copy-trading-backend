# ============================================================
# Hyperliquid Copy Trading Backend - Unified Environment Config
# ============================================================
# This file is shared by both analytics/ and api/
# Copy to .env and fill in the values
# ============================================================

# === REQUIRED ===

# MongoDB connections
MONGO_URI=mongodb://localhost:27017/hyperliquid_storage
AUTH_MONGO_URI=mongodb://localhost:27017/auth_db  # Same as core-exchange-api for user lookups

# Machine identification
MACHINE=hyperliquid-1
ENVIRONMENT=dev                         # dev, staging, prod
SERVICE_NAME=hyperliquid-api
PORT=3003

# Authentication (MUST match core-exchange-api for shared sessions)
JWT_SECRET=<same-as-core-exchange-api>
SHARED_PREFIX=<same-as-core-exchange-api>

# Redis (for session sharing with core-exchange-api)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# === OPTIONAL - Logging ===

LOG_LEVEL=info                          # debug, info, warn, error

# Better Stack / Logtail (cloud logging)
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_INGEST_ENDPOINT=                # analytics uses this (e.g., in.logs.betterstack.com)
LOGTAIL_INGESTING_HOST=                 # api uses this (same value as above)

# === OPTIONAL - Error Notifications ===

# Email notifications via AWS SES
ERROR_EMAILS=
SUPPORT_EMAIL=support@airavat.xyz
AWS_SES_PROFILE=ses-user
AWS_SES_REGION=ap-south-1

# === OPTIONAL - API Server ===

# Admin dashboard (HTTP Basic Auth)
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=

# === OPTIONAL - AWS Secrets Manager ===

# For .env.encoded decryption (production)
AWS_SECRET_NAME=aira_stack
AWS_SECRETS_PROFILE=secrets-user
AWS_SECRETS_REGION=eu-west-2

# === OPTIONAL - Analytics ===

# File locking for batch jobs (directory auto-created if missing)
LOCK_DIR=/tmp

# Debugging
INSTRUMENT=true                         # enable instrumentation logging
